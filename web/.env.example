# 复制为 .env.local 后修改值（.env.local 不入 git）

# JWT 签名密钥——生产环境必须用至少 32 字节的随机串
# 生成方法：node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
AUTH_JWT_SECRET=dev-only-change-me-to-a-random-64-byte-string

# SQLite 数据库文件路径
# 开发：./data/app.db（项目目录下，已在 .gitignore）
# 生产 CVM：/var/lib/python-lab/app.db
SQLITE_PATH=./data/app.db
